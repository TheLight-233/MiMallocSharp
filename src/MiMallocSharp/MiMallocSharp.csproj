<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>netstandard2.1;net8.0;net9.0;net10.0</TargetFrameworks>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>Mimalloc</RootNamespace>
    <AssemblyName>MiMallocSharp</AssemblyName>
    <PackageId>MiMallocSharp</PackageId>
    <Version>0.1.0</Version>
    <Description>A community C# translation of Microsoft's mimalloc allocator.</Description>
    <PackageTags>mimalloc;allocator;memory;performance;native;unsafe</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
